# Database
MONGO_URI=mongodb://localhost:27017/opensource-os

# JWT
JWT_SECRET=your-secret-key-change-in-production

# API Keys
OPENAI_API_KEY=your-openai-api-key-here
# (Text-to-speech and some AI features require a valid OpenAI key; TTS
# will be skipped if GROQ is used since groq.com does not support speech.)
# Groq (if you set a key, service will auto-enable Groq)
GROQ_API_KEY=your-groq-api-key-here
# Optional: override the Groq model used by the app.
# Defaults to 'openai/gpt-oss-120b' (Groq now recommends this; change when
# the provider deprecates it - see deprecation notices in the console).
GROQ_MODEL=openai/gpt-oss-120b
# Set to true to force Groq even without a key (not recommended)
GROQ_ENABLED=false
GITHUB_TOKEN=your-github-token-here

# GitHub OAuth (required for "Connect GitHub" and room/chat access)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
# Optional: override callback URL (default: SERVER_URL + /api/auth/github/callback)
# GITHUB_OAUTH_REDIRECT_URL=http://localhost:5000/api/auth/github/callback
# Optional: key to encrypt stored GitHub access tokens (default: JWT_SECRET)
# GITHUB_TOKEN_ENCRYPTION_KEY=your-encryption-key

# GitHub Webhooks (for PR notifications and analytics)
# GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Environment
NODE_ENV=development
PORT=5000

# Client URL (for CORS and OAuth redirect back to app)
CLIENT_URL=http://localhost:5173
# Public server URL (for OAuth callback and webhooks; e.g. https://your-app.onrender.com)
SERVER_URL=http://localhost:5000
